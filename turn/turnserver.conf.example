# Copy this file to turnserver.conf on your VPS and replace the values below.
#
# Required firewall ports:
# - 3478 TCP
# - 3478 UDP
# - 49152-65535 UDP

listening-port=3478
fingerprint
lt-cred-mech

# Use your VPS public IP here. If you use a domain, keep this as the public IP.
external-ip=YOUR_PUBLIC_IP

# Use a stable name. A domain is best, but a plain label also works.
realm=YOUR_PUBLIC_IP_OR_DOMAIN

# Pick a strong username and password.
user=your_username:your_password

# Relay port range used by WebRTC media.
min-port=49152
max-port=65535

# Keep this TURN-only. STUN is already handled by the app config.
no-cli
no-tls
no-dtls

# Avoid exposing local/private relay addresses.
no-multicast-peers
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=224.0.0.0-255.255.255.255
