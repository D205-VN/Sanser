{
  "name": "gameremote-parsec-like",
  "version": "0.1.0",
  "private": true,
  "description": "Single-app Parsec-like remote game streaming prototype with WebRTC.",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "node server.js",
    "desktop": "electron .",
    "start": "electron .",
    "check": "node --check server.js && node --check public/app.js && node --check desktop/main.js",
    "tailscale:install": "node scripts/install-tailscale.js",
    "native:host-win:configure": "cmake -S native/host-win -B native/host-win/build -G \"Visual Studio 17 2022\" -A x64",
    "native:host-win:build": "cmake --build native/host-win/build --config Release",
    "dist:win": "electron-builder --win portable --x64",
    "dist:win:installer": "electron-builder --win nsis --x64",
    "dist:mac": "electron-builder --mac zip --arm64",
    "dist:both": "npm run dist:mac && npm run dist:win"
  },
  "keywords": [
    "webrtc",
    "game-streaming",
    "remote-desktop"
  ],
  "author": "",
  "license": "UNLICENSED",
  "build": {
    "appId": "com.gameremote.desktop",
    "productName": "GameRemote",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "desktop/input-worker-win.ps1"
    ],
    "files": [
      "desktop/**/*",
      "native/host-win/build/Release/sanser-native-host.exe",
      "public/**/*",
      "scripts/**/*",
      "server.js",
      "package.json",
      "README.md"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable"
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-Windows-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-macOS-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Windows-${version}-portable-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  }
}
